# ============================================================================
# .vscodeignore — 控制 VSIX 打包内容
# ============================================================================
# 排除源码和开发文件，只保留构建产物和必要资源
# ============================================================================

# 源代码不进 VSIX
src/**
esbuild.config.mjs
tsconfig.json

# 开发依赖
node_modules/**

# 构建产物中的 map 文件（可选，发布时可去掉）
dist/**/*.map

# Monorepo 其他包源码（防止误打包）
../../core/**
../../gui/**

# 通用忽略
**/.gitignore
**/.DS_Store
**/Thumbs.db
**/*.log
