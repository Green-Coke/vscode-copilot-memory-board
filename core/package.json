{
  "name": "@memory-board/core",
  "version": "0.0.1",
  "private": true,
  "description": "Core logic for scanning, parsing, and mapping Copilot long-term memory files.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('tsconfig.tsbuildinfo',{force:true})\""
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
